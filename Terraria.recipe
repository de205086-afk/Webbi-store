SUMMARY="Terraria (user‑supplied proprietary game files)" DESCRIPTION="A launcher package for Terraria on Haiku. Game data must be provided by the user." HOMEPAGE="https://terraria.org/" COPYRIGHT="© Re-Logic" LICENSE="Proprietary" REVISION="1" SOURCE_URI="" CHECKSUM_SHA256="" ARCHITECTURES="x86_64" DISABLE_SOURCE_PACKAGE="yes" # No real source archive — user supplies files manually SOURCE_DIR="." BUILD_PREREQUIRES=" haikuporter " BUILD_REQUIRES=" mono " REQUIRES=" mono " INSTALL() { # Install launcher mkdir -p $appsDir/Terraria cp -r $sourceDir/data $appsDir/Terraria/ mkdir -p $binDir cat > $binDir/terraria < 

